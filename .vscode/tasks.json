{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build Debug",
            "type": "shell",
            "command": "g++",
            "args": [
                "-std=c++23",
                "-g",
                "-Wall",
                "-Wextra",
                "-Werror",
                "-Iinclude",
                "src/*.cpp",
                "-o",
                "build/app.exe"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": ["$gcc"]
        }
    ]
}